{
  "name": "riftbound",
  "version": "1.0.0",
  "description": "Riftbound Desktop App",
  "main": "main.cjs",
  "scripts": {
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm run dev",
    "start:electron": "wait-on http-get://localhost:5173/ && electron .",
    "dev": "concurrently -k \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:electron\"",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:backend": "cd backend && npm install",
    "prebuild": "npm run build:frontend && npm run build:backend",
    "build": "electron-builder build --win"
  },
  "build": {
    "appId": "com.riftbound.app",
    "productName": "Riftbound",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.cjs",
      "frontend/dist/**/*",
      "backend/**/*",
      "!backend/node_modules/**/*"
    ],
    "extraFiles": [
      {
        "from": "backend/node_modules",
        "to": "resources/backend/node_modules",
        "filter": ["**/*"]
      },
      {
        "from": "backend/.env",
        "to": "resources/backend/.env"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "riftboundFIS.ico"
    }
  },
  "author": "David",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  }
}
